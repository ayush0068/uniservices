/* Theme */
(function(){
  const KEY='uni-admin-theme',root=document.documentElement;
  function apply(t){root.setAttribute('data-theme',t);localStorage.setItem(KEY,t);document.querySelectorAll('.theme-toggle input[type="checkbox"]').forEach(c=>c.checked=t==='dark')}
  const saved=localStorage.getItem(KEY)||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');
  apply(saved);window.__applyTheme=apply;
  document.addEventListener('DOMContentLoaded',()=>{
    document.querySelectorAll('.theme-toggle input[type="checkbox"]').forEach(cb=>{cb.addEventListener('change',function(){window.__applyTheme(this.checked?'dark':'light')})});
  });
})();

let contacts = [];

/* ── Navigation ── */
const pages={};
document.querySelectorAll('.page').forEach(p=>pages[p.id.replace('page-','')]=p);
const navItems=document.querySelectorAll('.nav-item');
const topbarTitle=document.getElementById('topbarTitle');
const pageTitles={dashboard:'Dashboard',contacts:'Contact Messages',unicare:'UniCare+',unishow:'UniShow',unispace:'UniSpace',settings:'Settings'};

function goTo(name){
  navItems.forEach(n=>n.classList.toggle('active',n.dataset.page===name));
  Object.entries(pages).forEach(([k,v])=>v.classList.toggle('active',k===name));
  topbarTitle.textContent=pageTitles[name]||name;
  closeSidebar();
  if(name==='contacts')renderTable(contacts);
  if(name==='dashboard')renderDashboard();
}
navItems.forEach(n=>n.addEventListener('click',()=>goTo(n.dataset.page)));

/* ── Mobile sidebar ── */
const sidebar=document.getElementById('sidebar');
const overlay=document.getElementById('sidebarOverlay');
document.getElementById('mobileMenuBtn').addEventListener('click',()=>{sidebar.classList.add('open');overlay.classList.add('open')});
function closeSidebar(){sidebar.classList.remove('open');overlay.classList.remove('open')}
overlay.addEventListener('click',closeSidebar);

/* ── Date ── */
document.getElementById('currentDate').textContent=new Date().toLocaleDateString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

/* ── Fetch contacts from API ── */
async function fetchContacts(){
  try {
    const res = await fetch('/api/admin/contacts');
    const data = await res.json();
    if(data.success){
      contacts = data.contacts.map(c => ({
        id: c._id,
        name: c.name,
        email: c.email,
        subject: c.subject,
        message: c.message,
        date: c.createdAt,
        status: c.status || 'new'
      }));
    }
  } catch(e){ console.error('Failed to fetch contacts', e) }
}

/* ── Fetch stats from API ── */
async function fetchStats(){
  try {
    const res = await fetch('/api/admin/stats');
    const d = await res.json();
    if(d.success){
      document.getElementById('stat-total').textContent   = d.total;
      document.getElementById('stat-today').textContent   = d.today;
      document.getElementById('stat-week').textContent    = d.week;
      document.getElementById('stat-pending').textContent = d.pending;
      document.getElementById('ms-unicare').textContent   = d.unicare;
      document.getElementById('ms-unishow').textContent   = d.unishow;
      document.getElementById('ms-unispace').textContent  = d.unispace;
      document.getElementById('badge-count').textContent  = d.pending;
    }
  } catch(e){ console.error('Failed to fetch stats', e) }
}

/* ── Dashboard ── */
function renderDashboard(){
  const list=document.getElementById('recent-list');
  const recent=[...contacts].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,5);
  if(!recent.length){list.innerHTML='<div class="empty-state"><div class="empty-state-icon">📭</div><p>No messages yet.</p></div>';return}
  list.innerHTML=recent.map(c=>`
    <div class="activity-item" style="cursor:pointer" onclick="openModal('${c.id}')">
      <div class="activity-dot" style="background:${c.status==='new'?'var(--green)':c.status==='replied'?'var(--blue)':'var(--t3)'}"></div>
      <div class="activity-text"><strong>${c.name}</strong> — ${c.message.slice(0,60)}…</div>
      <div class="activity-time">${timeAgo(c.date)}</div>
    </div>`).join('');
}

/* ── Table ── */
function subjectLabel(s){return{general:'General',unicare:'UniCare+',unishow:'UniShow',unispace:'UniSpace',partnership:'Partnership',press:'Press',careers:'Careers'}[s]||s}
function subjectBadge(s){return{unicare:'badge-green',unishow:'badge-gold',unispace:'badge-rose',partnership:'badge-blue'}[s]||'badge-gray'}
function statusBadge(s){return s==='new'?'badge-green':s==='replied'?'badge-blue':'badge-gray'}

function renderTable(data){
  const tbody=document.getElementById('contactsTbody');
  if(!data.length){tbody.innerHTML='<tr><td colspan="8"><div class="empty-state"><div class="empty-state-icon">🔍</div><p>No results found.</p></div></td></tr>';return}
  tbody.innerHTML=data.map((c,i)=>`
    <tr>
      <td style="color:var(--t3);font-size:0.76rem">${String(i+1).padStart(2,'0')}</td>
      <td style="font-weight:600;color:var(--t1)">${c.name}</td>
      <td><a href="mailto:${c.email}" style="color:var(--green)">${c.email}</a></td>
      <td><span class="badge ${subjectBadge(c.subject)}">${subjectLabel(c.subject)}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.message}</td>
      <td style="white-space:nowrap;font-size:0.78rem">${new Date(c.date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})}</td>
      <td>
        <select class="filter-select" style="height:28px;font-size:0.72rem;padding:0 1.5rem 0 0.5rem" onchange="updateStatus('${c.id}',this.value)">
          <option value="new"     ${c.status==='new'?'selected':''}>New</option>
          <option value="read"    ${c.status==='read'?'selected':''}>Read</option>
          <option value="replied" ${c.status==='replied'?'selected':''}>Replied</option>
        </select>
      </td>
      <td style="display:flex;gap:6px">
        <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('${c.id}')" title="View">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
        <button class="btn btn-ghost btn-sm btn-icon" onclick="deleteContact('${c.id}')" title="Delete" style="color:var(--red,#c0392b)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </td>
    </tr>`).join('');
}

function filterTable(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  const sub=document.getElementById('subjectFilter').value;
  const st=document.getElementById('statusFilter').value;
  const filtered=contacts.filter(c=>
    (!q||c.name.toLowerCase().includes(q)||c.email.toLowerCase().includes(q)||c.message.toLowerCase().includes(q))&&
    (!sub||c.subject===sub)&&(!st||c.status===st));
  renderTable(filtered);
}

/* ── Update status ── */
async function updateStatus(id, status){
  try {
    const res = await fetch(`/api/admin/contacts/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});
    const d = await res.json();
    if(d.success){
      const c=contacts.find(x=>x.id===id);
      if(c)c.status=status;
      await fetchStats();
    }
  } catch(e){ console.error(e) }
}

/* ── Delete ── */
async function deleteContact(id){
  if(!confirm('Delete this message permanently?'))return;
  try {
    const res=await fetch(`/api/admin/contacts/${id}`,{method:'DELETE'});
    const d=await res.json();
    if(d.success){
      contacts=contacts.filter(c=>c.id!==id);
      renderTable(contacts);
      await fetchStats();
    }
  } catch(e){ console.error(e) }
}

/* ── Modal ── */
let currentContactId = null;

/* ── openModal ── */
function openModal(id) {
  const c = contacts.find(x => x.id === id);
  if (!c) return;
  currentContactId = id;

  document.getElementById('modalBody').innerHTML = `
    <div class="modal-row"><div class="modal-label">From</div><div class="modal-val">${c.name}</div></div>
    <div class="modal-row"><div class="modal-label">Email</div><div class="modal-val"><a href="mailto:${c.email}" style="color:var(--green)">${c.email}</a></div></div>
    <div class="modal-row"><div class="modal-label">Subject</div><div class="modal-val">${subjectLabel(c.subject)}</div></div>
    <div class="modal-row"><div class="modal-label">Received</div><div class="modal-val">${new Date(c.date).toLocaleString('en-IN')}</div></div>
    <div class="modal-row">
      <div class="modal-label">Status</div>
      <div class="modal-val"><span class="badge ${statusBadge(c.status)}">${c.status}</span></div>
    </div>
    ${c.repliedAt ? `<div class="modal-row"><div class="modal-label">Replied At</div><div class="modal-val">${new Date(c.repliedAt).toLocaleString('en-IN')}</div></div>` : ''}
    <div class="modal-row"><div class="modal-label">Message</div><div class="modal-val" style="white-space:pre-wrap;line-height:1.75">${c.message}</div></div>
    ${c.replyMessage ? `<div class="modal-row"><div class="modal-label">Your Last Reply</div><div class="modal-val" style="white-space:pre-wrap;line-height:1.75;border-left:3px solid var(--green);padding-left:0.75rem;">${c.replyMessage}</div></div>` : ''}`;

  /* Pre-fill subject */
  document.getElementById('replySubject').value = `Re: ${subjectLabel(c.subject)} — UNI-SERVICES`;
  document.getElementById('replyMessage').value = '';
  document.getElementById('replyStatus').style.display = 'none';
  toggleReply(false);

  document.getElementById('modalOverlay').classList.add('open');

  /* Mark as read */
  if (c.status === 'new') updateStatus(id, 'read');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  currentContactId = null;
}

/* ── Toggle reply form ── */
function toggleReply(show) {
  document.getElementById('replySection').style.display  = show ? 'block' : 'none';
  document.getElementById('modalActions').style.display  = show ? 'none'  : 'flex';
  if (show) document.getElementById('replyMessage').focus();
}

/* ── Send reply ── */
async function sendReply() {
  const msg  = document.getElementById('replyMessage').value.trim();
  const subj = document.getElementById('replySubject').value.trim();
  const btn  = document.getElementById('sendReplyBtn');
  const statusEl = document.getElementById('replyStatus');

  if (!msg) {
    statusEl.textContent = '⚠ Please write a reply message.';
    statusEl.className = 'reply-error';
    statusEl.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Sending…`;

  try {
    const res = await fetch(`/api/admin/contacts/${currentContactId}/reply`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ replyMessage: msg, replySubject: subj })
    });
    const data = await res.json();

    if (data.success) {
      /* Update local state */
      const c = contacts.find(x => x.id === currentContactId);
      if (c) { c.status = 'replied'; c.replyMessage = msg; c.repliedAt = new Date().toISOString(); }

      statusEl.textContent = `✓ Reply sent successfully!`;
      statusEl.className = 'reply-success';
      statusEl.style.display = 'block';
      btn.innerHTML = '✓ Sent!';

      /* Refresh table + stats */
      renderTable(contacts);
      await fetchStats();

      /* Close after 1.8s */
      setTimeout(() => closeModal(), 1800);
    } else {
      statusEl.textContent = `✗ ${data.message}`;
      statusEl.className = 'reply-error';
      statusEl.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Reply`;
    }
  } catch (err) {
    statusEl.textContent = '✗ Network error. Try again.';
    statusEl.className = 'reply-error';
    statusEl.style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Reply`;
  }
}

/* Spin animation */
document.head.insertAdjacentHTML('beforeend',`<style>@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}</style>`);

document.getElementById('modalOverlay').addEventListener('click', function(e) { if (e.target === this) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

/* ── Export CSV ── */
function exportCSV(){
  const headers=['#','Name','Email','Subject','Message','Date','Status'];
  const rows=contacts.map((c,i)=>[i+1,`"${c.name}"`,c.email,subjectLabel(c.subject),`"${c.message.replace(/"/g,'""')}"`,new Date(c.date).toLocaleDateString('en-IN'),c.status]);
  const csv=[headers,...rows].map(r=>r.join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download=`uni-contacts-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
}

/* ── Time ago ── */
function timeAgo(d){
  const diff=(Date.now()-new Date(d))/1000;
  if(diff<60)return'Just now';
  if(diff<3600)return Math.floor(diff/60)+'m ago';
  if(diff<86400)return Math.floor(diff/3600)+'h ago';
  return Math.floor(diff/86400)+'d ago';
}

/* ── Init ── */
(async function init(){
  await fetchContacts();
  await fetchStats();
  renderDashboard();
})();

const S_KEY = 'uni-admin-settings';
function sGet(){return JSON.parse(localStorage.getItem(S_KEY)||'{}')}
function sSet(s){localStorage.setItem(S_KEY,JSON.stringify(s))}
function sSave(k,v){const s=sGet();s[k]=v;sSet(s);document.getElementById('ss-lastsaved').textContent='Just now'}

function sToast(msg,err=false){
  const t=document.getElementById('s-toast');
  t.className='s-show'+(err?' s-err':'');
  t.innerHTML=`<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">${err?'<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>':'<polyline points="20 6 9 17 4 12"/>'}</svg>${msg}`;
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('s-show'),2800);
}

function sToggle(head){
  head.classList.toggle('s-open');
  head.nextElementSibling.classList.toggle('s-open');
}

function sPickColor(el){
  document.querySelectorAll('#ss-accents .clr-sw').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  sSave('accentColor',el.dataset.c);
  sToast('Accent color saved — update CSS variable to apply');
}

function sToggleMaint(on){
  document.getElementById('ss-maintbadge').style.display=on?'inline-flex':'none';
  sSave('maintenance',on);
  sToast(on?'⚠ Maintenance mode ON':'Maintenance mode OFF');
}

function sSettingsSaveAll(){
  const s=sGet();
  s.savedAt=new Date().toLocaleTimeString('en-IN');
  sSet(s);
  document.getElementById('ss-lastsaved').textContent=s.savedAt;
  sToast('All settings saved!');
}

function sLoadSettings(){
  if(!confirm('Revert all settings to defaults?'))return;
  localStorage.removeItem(S_KEY);
  sToast('Settings reverted');
  setTimeout(()=>{
    const pg=document.getElementById('page-settings');
    if(pg){pg.classList.remove('active');setTimeout(()=>pg.classList.add('active'),50)}
  },600);
}

function sDanger(action){
  const msgs={clearContacts:'delete ALL contact messages? This CANNOT be undone.',resetSettings:'reset all settings to defaults?'};
  if(!confirm('Are you sure you want to '+msgs[action]))return;
  if(action==='resetSettings'){sLoadSettings();return}
  if(action==='clearContacts'){
    fetch('/api/admin/contacts/clear-all',{method:'DELETE'})
      .then(r=>r.json())
      .then(d=>{
        if(d.success){contacts=[];renderTable([]);fetchStats();sToast('All contacts deleted')}
        else sToast(d.message||'Error',true);
      })
      .catch(()=>sToast('Add route in app.js first',true));
  }
}

/* Load saved values */
(function(){
  const s=sGet();
  if(s.savedAt)document.getElementById('ss-lastsaved').textContent=s.savedAt;
  if(s.siteName){const el=document.querySelector('#page-settings input[onchange*="siteName"]');if(el)el.value=s.siteName}
  if(s.maintenance){const el=document.getElementById('ss-maint');if(el){el.checked=true;sToggleMaint(true)}}
})();
</script>
</body>
</html>