<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | UNI-SERVICES Admin</title>
    <link rel="stylesheet" href="admin.css">
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar (same as dashboard) -->
        <aside class="sidebar">
            <!-- ... sidebar content ... -->
        </aside>
        
        <main class="admin-main">
            <div class="admin-header">
                <h1>Contact Submissions</h1>
                <div class="admin-actions">
                    <span class="total-count">Total: <%= total %></span>
                </div>
            </div>
            
            <!-- Filter Tabs -->
            <div class="filter-tabs">
                <a href="/admin-contact?status=all" class="<%= currentStatus === 'all' ? 'active' : '' %>">All</a>
                <a href="/admin-contact?status=new" class="<%= currentStatus === 'new' ? 'active' : '' %>">New</a>
                <a href="/admin-contact?status=read" class="<%= currentStatus === 'read' ? 'active' : '' %>">Read</a>
                <a href="/admin-contact?status=replied" class="<%= currentStatus === 'replied' ? 'active' : '' %>">Replied</a>
                <a href="/admin-contact?status=archived" class="<%= currentStatus === 'archived' ? 'active' : '' %>">Archived</a>
            </div>
            
            <!-- Contacts Table -->
            <div class="card">
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% contacts.forEach(contact => { %>
                                <tr>
                                    <td><%= contact.name %></td>
                                    <td><%= contact.email %></td>
                                    <td><%= contact.subject %></td>
                                    <td>
                                        <select class="status-select" data-id="<%= contact._id %>">
                                            <option value="new" <%= contact.status === 'new' ? 'selected' : '' %>>New</option>
                                            <option value="read" <%= contact.status === 'read' ? 'selected' : '' %>>Read</option>
                                            <option value="replied" <%= contact.status === 'replied' ? 'selected' : '' %>>Replied</option>
                                            <option value="archived" <%= contact.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                        </select>
                                    </td>
                                    <td><%= new Date(contact.createdAt).toLocaleDateString() %></td>
                                    <td class="actions">
                                        <a href="/admin-contact/<%= contact._id %>" class="btn btn-sm">View</a>
                                        <button class="btn btn-sm btn-danger delete-contact" data-id="<%= contact._id %>">Delete</button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin-contact?page=<%= i %>&status=<%= currentStatus %>" 
                           class="<%= i === currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>
    
    <script src="admin.js"></script>
</body>
</html>