<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title><%= title %> | UNI-SERVICES</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:       #faf9f7;
  --bg2:      #f4f2ef;
  --card:     #ffffff;
  --border:   rgba(0,0,0,0.08);
  --border2:  rgba(0,0,0,0.15);
  --green:    #2d4a3e;
  --green2:   #3d6454;
  --green-lt: rgba(45,74,62,0.08);
  --gold:     #c9933a;
  --t1:       #1a1a18;
  --t2:       #5a5a54;
  --t3:       #9a9a92;
  --inv:      #faf9f7;
  --red:      #c0392b;
  --red-lt:   rgba(192,57,43,0.08);
}
[data-theme="dark"] {
  --bg:       #04060f;
  --bg2:      #080c1a;
  --card:     rgba(255,255,255,0.04);
  --border:   rgba(255,255,255,0.09);
  --border2:  rgba(255,255,255,0.18);
  --green:    #5fad8e;
  --green2:   #4a9478;
  --green-lt: rgba(95,173,142,0.12);
  --t1:       #eef0f8;
  --t2:       #8b90a8;
  --t3:       #4a5070;
  --inv:      #04060f;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px}
body{
  font-family:'Inter',sans-serif;
  background:var(--bg);
  color:var(--t1);
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  -webkit-font-smoothing:antialiased;
  overflow:hidden;
  transition:background 0.3s ease;
}

/* ── Background orbs ── */
.bg-orbs{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.orb{position:absolute;border-radius:50%;filter:blur(100px);animation:orbDrift 16s ease-in-out infinite}
.orb-1{width:600px;height:600px;background:rgba(45,74,62,0.07);top:-200px;left:-150px;animation-delay:0s}
.orb-2{width:500px;height:500px;background:rgba(201,147,58,0.05);bottom:-100px;right:-100px;animation-delay:-6s}
.orb-3{width:350px;height:350px;background:rgba(124,158,143,0.06);top:40%;left:40%;animation-delay:-11s}
[data-theme="dark"] .orb-1{background:rgba(95,173,142,0.1)}
[data-theme="dark"] .orb-2{background:rgba(232,184,109,0.07)}
@keyframes orbDrift{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-30px) scale(1.04)}}

/* ── Card ── */
.login-wrap{
  position:relative;z-index:2;
  width:100%;max-width:420px;
  padding:1.5rem;
  animation:fadeUp 0.55s cubic-bezier(0.4,0,0.2,1);
}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

.login-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:24px;
  padding:2.5rem 2.25rem;
  box-shadow:0 20px 60px rgba(0,0,0,0.1);
  backdrop-filter:blur(12px);
}
[data-theme="dark"] .login-card{box-shadow:0 20px 60px rgba(0,0,0,0.5)}

/* ── Logo area ── */
.login-logo{
  text-align:center;
  margin-bottom:2rem;
}
.login-logo-icon{
  width:56px;height:56px;border-radius:16px;
  background:var(--green-lt);
  border:1px solid rgba(45,74,62,0.2);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 1rem;
  font-size:1.5rem;
  animation:iconPulse 3s ease-in-out infinite;
}
[data-theme="dark"] .login-logo-icon{border-color:rgba(95,173,142,0.25)}
@keyframes iconPulse{0%,100%{box-shadow:0 0 0 0 rgba(45,74,62,0.15)}50%{box-shadow:0 0 0 8px rgba(45,74,62,0)}}
@keyframes iconPulseDark {
  0%,100% { box-shadow: 0 0 0 0 rgba(95,173,142,0.2); }
  50%     { box-shadow: 0 0 0 8px rgba(95,173,142,0); }
}
[data-theme="dark"] .login-logo-icon {
  animation-name: iconPulseDark;
}

.login-logo-name{
  font-family:'Playfair Display',serif;
  font-size:1.35rem;font-weight:800;
  color:var(--green);
  letter-spacing:0.02em;
  margin-bottom:4px;
}
.login-logo-sub{
  font-size:0.78rem;color:var(--t3);
  letter-spacing:0.06em;text-transform:uppercase;font-weight:500;
}

/* ── Form ── */
.form-group{margin-bottom:1.15rem}
.form-label{
  display:block;
  font-size:0.78rem;font-weight:600;
  letter-spacing:0.05em;
  color:var(--t2);
  margin-bottom:0.45rem;
}
.input-wrap{position:relative}
.input-icon{
  position:absolute;left:12px;top:50%;
  transform:translateY(-50%);
  color:var(--t3);pointer-events:none;
  display:flex;align-items:center;
}
.form-input{
  width:100%;height:46px;
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:0 1rem 0 2.6rem;
  font-family:'Inter',sans-serif;
  font-size:0.9rem;color:var(--t1);
  outline:none;
  transition:border-color 0.2s ease,box-shadow 0.2s ease,background 0.2s ease;
}
.form-input::placeholder{color:var(--t3)}
.form-input:focus{
  border-color:var(--green);
  background:var(--card);
  box-shadow:0 0 0 3px rgba(45,74,62,0.1);
}
[data-theme="dark"] .form-input:focus{box-shadow:0 0 0 3px rgba(95,173,142,0.15)}

/* Password toggle */
.pwd-toggle{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;
  color:var(--t3);padding:4px;
  display:flex;align-items:center;
  transition:color 0.2s ease;
}
.pwd-toggle:hover{color:var(--green)}

/* Error alert */
.error-alert{
  display:flex;align-items:center;gap:8px;
  background:var(--red-lt);
  border:1px solid rgba(192,57,43,0.2);
  border-radius:10px;
  padding:0.75rem 1rem;
  margin-bottom:1.25rem;
  font-size:0.83rem;color:var(--red);
  animation:shake 0.4s ease;
}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}60%{transform:translateX(6px)}80%{transform:translateX(-3px)}}

/* Submit btn */
.btn-login{
  width:100%;height:46px;
  background:var(--green);color:var(--inv);
  border:none;border-radius:10px;
  font-family:'Inter',sans-serif;
  font-size:0.9rem;font-weight:600;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:background 0.2s ease,transform 0.15s ease,box-shadow 0.2s ease;
  box-shadow:0 4px 14px rgba(45,74,62,0.25);
  margin-top:0.25rem;
}
.btn-login:hover{background:var(--green2);transform:translateY(-1px);box-shadow:0 6px 20px rgba(45,74,62,0.35)}
.btn-login:active{transform:translateY(0)}

/* Divider */
.login-divider{
  text-align:center;
  font-size:0.72rem;color:var(--t3);
  margin:1.5rem 0 1rem;
  position:relative;
}
.login-divider::before,.login-divider::after{
  content:'';position:absolute;top:50%;
  width:calc(50% - 40px);height:1px;
  background:var(--border);
}
.login-divider::before{left:0}
.login-divider::after{right:0}

/* Footer */
.login-footer{
  text-align:center;
  margin-top:1.5rem;
  font-size:0.75rem;color:var(--t3);
}
.login-footer a{color:var(--green);text-decoration:none;font-weight:500}
.login-footer a:hover{text-decoration:underline}

/* Theme toggle */
.theme-toggle-wrap{position:fixed;top:1.25rem;right:1.25rem;z-index:10}
.theme-toggle{position:relative;width:44px;height:26px;cursor:pointer;flex-shrink:0;background:none;border:none;padding:0;display:inline-block}
.theme-toggle input{opacity:0;width:0;height:0;position:absolute;pointer-events:none}
.toggle-track{position:absolute;inset:0;border-radius:26px;background:#d1d1d6;transition:background 0.3s ease;overflow:hidden}
[data-theme="dark"] .toggle-track{background:#34c759}
.toggle-icon--sun{position:absolute;right:5px;top:50%;transform:translateY(-50%);display:flex;align-items:center;justify-content:center;opacity:1;transition:opacity 0.2s ease;pointer-events:none}
.toggle-icon--moon{position:absolute;left:5px;top:50%;transform:translateY(-50%);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s ease;pointer-events:none}
[data-theme="dark"] .toggle-icon--sun{opacity:0}
[data-theme="dark"] .toggle-icon--moon{opacity:1}
.toggle-thumb{position:absolute;top:2px;left:2px;width:22px;height:22px;border-radius:50%;background:#fff;box-shadow:0 2px 5px rgba(0,0,0,0.22);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1),width 0.15s ease;z-index:2}
[data-theme="dark"] .toggle-thumb{transform:translateX(18px)}
.theme-toggle:active .toggle-thumb{width:26px}
[data-theme="dark"] .theme-toggle:active .toggle-thumb{transform:translateX(14px);width:26px}
</style>
</head>
<body>

<div class="bg-orbs">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<!-- Theme toggle -->
<div class="theme-toggle-wrap">
  <label class="theme-toggle" aria-label="Toggle dark mode">
    <input type="checkbox" id="themeCheckbox" tabindex="-1">
    <div class="toggle-track">
      <span class="toggle-icon--sun"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/></svg></span>
      <span class="toggle-icon--moon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
    </div>
    <div class="toggle-thumb"></div>
  </label>
</div>

<div class="login-wrap">
  <div class="login-card">

    <!-- Logo -->
    <div class="login-logo">
      <div class="login-logo-icon">⬡</div>
      <div class="login-logo-name">UNI-SERVICES</div>
      <div class="login-logo-sub">Admin Portal</div>
    </div>

    <!-- Error -->
    <% if (error) { %>
    <div class="error-alert">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= error %>
    </div>
    <% } %>

    <!-- Form -->
    <form action="/admin/login" method="POST" autocomplete="off">

      <div class="form-group">
        <label class="form-label" for="username">Username</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          <input
            type="text"
            id="username"
            name="username"
            class="form-input"
            placeholder="Enter admin username"
            autocomplete="username"
            required
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input
            type="password"
            id="password"
            name="password"
            class="form-input"
            placeholder="Enter password"
            autocomplete="current-password"
            required
          />
          <button type="button" class="pwd-toggle" id="pwdToggle" aria-label="Show password">
            <svg id="eyeIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-login">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Sign In to Dashboard
      </button>

    </form>

    <div class="login-divider">secured access</div>

    <div class="login-footer">
      <a href="/">← Back to UNI-SERVICES</a>
    </div>

  </div>
</div>

<script>
/* Theme */
(function(){
  const KEY='uni-theme',root=document.documentElement;
  function apply(t){root.setAttribute('data-theme',t);localStorage.setItem(KEY,t);document.querySelectorAll('.theme-toggle input').forEach(c=>c.checked=t==='dark')}
  apply(localStorage.getItem(KEY)||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'));
  document.addEventListener('DOMContentLoaded',()=>{
    document.querySelectorAll('.theme-toggle input').forEach(cb=>cb.addEventListener('change',function(){apply(this.checked?'dark':'light')}));
  });
})();

/* Password toggle */
document.getElementById('pwdToggle').addEventListener('click', function(){
  const inp = document.getElementById('password');
  const isText = inp.type === 'text';
  inp.type = isText ? 'password' : 'text';
  document.getElementById('eyeIcon').innerHTML = isText
    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
    : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
});
</script>
</body>
</html>