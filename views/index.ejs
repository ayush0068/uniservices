<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= settings.metaDesc %>" />
  <% if (!settings.searchIndex) { %><meta name="robots" content="noindex,nofollow" /><% } %>
  <title><%= settings.siteName %> | Your Digital Ecosystem</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⬡</text></svg>" />
</head>
<body>

  <div id="page-loader">
    <div class="loader-inner">
      <div class="loader-logo"><%= settings.siteName %></div>
      <div class="loader-bar"><div class="loader-bar-fill"></div></div>
    </div>
  </div>

  <div class="bg-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <%- include('navbar') %>

  <div class="nav-mobile" id="navMobile">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/contact" class="nav-cta">Get in Touch</a>
  </div>

  <main>

    <!-- HERO -->
    <section class="hero section" id="home">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <div class="hero-eyebrow reveal">
              <span class="eyebrow-dot"></span>
              Introducing the Digital Ecosystem
            </div>
            <h1 class="hero-title reveal reveal-delay-1">
              One Portal.<br />
              <span class="gradient-text">Infinite Possibilities.</span>
            </h1>
            <p class="hero-subtitle reveal reveal-delay-2">
              <%= settings.siteName %> brings together healthcare, entertainment, and cloud storage under one intelligent, beautifully designed platform — built for the way you live.
            </p>
            <div class="hero-actions reveal reveal-delay-3">
              <a href="#services" class="btn btn-primary">
                Explore Services
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/about" class="btn btn-ghost">Learn More</a>
            </div>
            <div class="hero-stats reveal reveal-delay-4">
              <div class="stat-item">
                <div class="stat-number"><%= services.length %></div>
                <div class="stat-label">Core Services</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">50K+</div>
                <div class="stat-label">Active Users</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">99.9%</div>
                <div class="stat-label">Uptime SLA</div>
              </div>
            </div>
          </div>

          <!-- Hero Visual -->
          <div class="hero-visual reveal reveal-delay-2" aria-hidden="true">
            <div class="hero-visual-inner">
              <div class="hero-center-orb">
                <div class="hub-icon">⬡</div>
              </div>
              <% services.forEach((svc, i) => { %>
              <div class="hero-float-card">
                <div class="float-icon <%= svc.iconClass %>"><%= svc.icon %></div>
                <div class="float-card-text">
                  <div class="float-card-name"><%= svc.name %></div>
                  <div class="float-card-sub"><%= svc.tagline %></div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services-section section" id="services">
      <div class="container">
        <div class="services-header">
          <div>
            <div class="section-tag reveal">Our Services</div>
            <h2 class="section-title reveal reveal-delay-1">
              <%= services.length === 3 ? 'Three Pillars of' : services.length + ' Pillars of' %><br />Modern Digital Life
            </h2>
          </div>
          <p class="section-subtitle reveal reveal-delay-2" style="text-align:right;">
            Each service is independently powerful, yet seamlessly integrated within the <%= settings.siteName %> ecosystem.
          </p>
        </div>

        <div class="services-grid">
          <% services.forEach((svc, i) => { %>
          <article class="service-card <%= svc.accentClass %> reveal <%= i > 0 ? 'reveal-delay-' + i : '' %>" tabindex="0">
            <div class="card-content">
              <div class="card-icon-wrap <%= svc.iconClass %>"><%= svc.icon %></div>
              <div class="card-badge <%= svc.badgeClass %>"><%= svc.badgeText %></div>
              <h3 class="card-name"><%= svc.name %></h3>
              <p class="card-desc"><%= svc.description %></p>
            </div>
            <div class="card-features">
              <% svc.features.forEach(f => { %>
              <div class="card-feature-item">
                <span class="feature-dot <%= svc.dotClass %>"></span>
                <%= f %>
              </div>
              <% }) %>
            </div>
            <div class="card-footer">
              <a href="<%= svc.href %>"
                 <%= svc.external ? 'target="_blank" rel="noopener"' : '' %>
                 class="card-link <%= svc.linkClass %>">
                Explore
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
          <% }) %>
        </div>

      </div>
    </section>

    <!-- WHY CHOOSE US -->
    <section class="why-section section">
      <div class="container">
        <div class="section-header">
          <div class="section-tag reveal" style="justify-content:center;">Why Choose Us</div>
          <h2 class="section-title reveal reveal-delay-1" style="text-align:center;">Built Different. Built Better.</h2>
          <p class="section-subtitle reveal reveal-delay-2">
            We didn't just build three apps — we engineered a unified platform designed around your real daily needs.
          </p>
        </div>
        <div class="why-grid">
          <div class="why-card reveal">
            <div class="why-icon">🔒</div>
            <h4>Privacy First</h4>
            <p>Zero-knowledge architecture and end-to-end encryption across all services. Your data is yours — always.</p>
          </div>
          <div class="why-card reveal reveal-delay-1">
            <div class="why-icon">⚡</div>
            <h4>Lightning Fast</h4>
            <p>Edge-deployed infrastructure ensures sub-100ms response times globally. No lag, ever.</p>
          </div>
          <div class="why-card reveal reveal-delay-2">
            <div class="why-icon">🔗</div>
            <h4>Deeply Unified</h4>
            <p>One account. One dashboard. All three services connected with a single sign-on and shared identity.</p>
          </div>
          <div class="why-card reveal reveal-delay-3">
            <div class="why-icon">🤝</div>
            <h4>Human Support</h4>
            <p>Real support agents, 24/7. No bots, no runarounds — just fast, empathetic help when you need it.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section section">
      <div class="container">
        <div class="cta-box reveal">
          <div class="section-tag">Start Today</div>
          <h2 class="section-title">Ready to Experience<br />the Full Ecosystem?</h2>
          <p class="section-subtitle">
            Join thousands of users already living smarter with <%= settings.siteName %>. Free to start. No credit card required.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">
              Get Started Free
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/about" class="btn btn-ghost">Learn About Us</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <%- include('footer') %>
  <script src="script.js"></script>
</body>
</html>